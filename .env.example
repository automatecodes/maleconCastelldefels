# ============================================================
#  El Malecón de la Salsa — Variables de entorno (.env)
#  Copia este fichero a `.env` y rellena los valores reales.
# ============================================================

DOMAIN=elmaleconcastelldefels.com
ENV=production

# --- Seguridad / Admin ---
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
ADMIN_EMAIL=admin@elmaleconcastelldefels.com
ADMIN_PASSWORD=cambia-esta-contrasena

# --- Base de datos PostgreSQL ---
POSTGRES_USER=malecon
POSTGRES_PASSWORD=cambia-esta-contrasena-db
POSTGRES_DB=malecon
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Email (Gmail + App Password al arranque) ---
# Cambiable a Brevo/SES editando solo estas líneas.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=          # requiere 2FA + contraseña de aplicación (16 dígitos)
SMTP_FROM=

# --- WhatsApp ---
WHATSAPP_NUMBER=+34672895239

# --- Redes sociales (se añaden al construir; vacío = feed con placeholders) ---
FB_TOKEN=
IG_TOKEN=
YOUTUBE_API_KEY=
TIKTOK_TOKEN=
SOCIAL_REFRESH_SECONDS=1800

# --- Generación de imágenes IA (etapa inicial) ---
# IMAGE_AI_PROVIDER: openai | stability | (vacío → placeholder de marca offline)
IMAGE_AI_PROVIDER=
IMAGE_AI_KEY=
IMAGE_AI_MODEL=           # opcional: openai→gpt-image-1 (def) · stability→core (def)
IMAGE_AI_SIZE=1024x1024

# --- Pagos (fase futura §11) — dejar vacío por ahora ---
PAYMENT_PROVIDER=
PAYMENT_KEY=

# --- Reverse proxy (nginx-proxy + acme-companion) ---
LETSENCRYPT_EMAIL=tu-email@ejemplo.com
